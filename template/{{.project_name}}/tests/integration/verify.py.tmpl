# COMMAND ----------

cfg = load_config(dbutils, spark)

# COMMAND ----------

catalog_name = cfg.catalog_name
ingestion_schema_name = cfg.ingestion_schema_name
analytics_schema_name = cfg.analytics_schema_name

EXPECTED_OUTPUTS = load_scenario('basic').EXPECTED_OUTPUTS

table_map = {
    'expected_enriched_telemetry': f'{catalog_name}.{ingestion_schema_name}.{ENRICHED_TELEMETRY}',
    'expected_equipment_metrics': f'{catalog_name}.{analytics_schema_name}.{EQUIPMENT_METRICS}',
    'expected_anomaly_alerts': f'{catalog_name}.{analytics_schema_name}.{ANOMALY_ALERTS}',
}

for expected_key, actual_fqn in table_map.items():
    expected = EXPECTED_OUTPUTS[expected_key](spark)
    actual = spark.table(actual_fqn)
    assert_df_equality(actual, expected, ignore_row_order=True, ignore_metadata=True)
    print(f'PASS: {actual_fqn}')
