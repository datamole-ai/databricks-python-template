[build-system]
requires = ["uv_build>=0.11.6,<0.12"]
build-backend = "uv_build"

[project]
name = "{{.project_name}}"
version = "0.0.1"
requires-python = ">=3.11"
dependencies = ["pyyaml", "chispa", "databricks-sdk"]

[dependency-groups]
dev = [
    "pysail==0.5.3",
    "pyspark-client==4.1.1",
    "pytest",
    "ruff",
]

[tool.pytest.ini_options]
testpaths = ["tests"]

[tool.ruff]
line-length = 120

[tool.ruff.lint.per-file-ignores]
"notebooks/**/*.py" = ["F821"]
"tests/integration/**/*.py" = ["F821"]
